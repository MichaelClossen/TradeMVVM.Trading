<Window x:Class="TradeMVVM.ReadHoldings.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeMVVM.ReadHoldings"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"   MinWidth="520">

    <Grid>
        <!--<Grid.ColumnDefinitions>
            --><!-- Make left column size to its content (the DataGrid) so the splitter aligns to the last column --><!--
            <ColumnDefinition x:Name="ColLeft" Width="*" MinWidth="300" />
            <ColumnDefinition Width="8" />
            --><!-- right column takes remaining space (ensure minimum so inner splitter is visible) --><!--
            <ColumnDefinition x:Name="ColRight" Width="*" MinWidth="80" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="ColRightRight"  Width="*" MinWidth="80" />
        </Grid.ColumnDefinitions>-->
        <Grid.ColumnDefinitions>

            <!-- Links -->
            <ColumnDefinition x:Name="ColLeft"
                      Width="Auto"
                      MinWidth="300"
                              MaxWidth="1010"/>

            <ColumnDefinition Width="8"/>

            <!-- Mitte -->
            <ColumnDefinition x:Name="ColRight" Width="*"/>

           

        </Grid.ColumnDefinitions>
        <!-- Left: controls above holdings table -->
        <Grid Grid.Column="0" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Name="BtnOpenCsv" Width="120" Height="28" Click="BtnOpenCsv_Click">CSV öffnen...</Button>
                        <Button Name="BtnExportCsv" Width="120" Height="28" Margin="8,0,0,0" Click="BtnExportCsv_Click">Export CSV</Button>
                    </StackPanel>

                    <TextBlock Name="TxtPath" Grid.Column="1" Margin="8,4,0,0" VerticalAlignment="Center">Kein Pfad ausgewählt</TextBlock>

                    <TextBlock Name="TxtClock" Grid.Column="2" Margin="8,4,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" FontSize="32">--:--:--</TextBlock>
                </Grid>
                <TextBlock Name="TxtInfo" Margin="0,0,0,6" Text="" />
                <!-- summary removed: numbers above the list disabled -->
            </StackPanel>
            <DataGrid Name="DgHoldings" Grid.Row="1" AutoGenerateColumns="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" CanUserAddRows="False"  >

                <DataGrid.RenderTransform>
                    <ScaleTransform x:Name="DgScale"
                    ScaleX="1"
                    ScaleY="1" />
                </DataGrid.RenderTransform>

                <DataGrid.RenderTransformOrigin>
                    0,0
                </DataGrid.RenderTransformOrigin>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Isin}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="ISIN" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Name}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Name" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Trail, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Trail" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn  Binding="{Binding Shares, StringFormat='{}{0:0}'}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="#" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding AvgBuyPrice, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Ø Buy" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding TotalValue, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Ø Gesamtwert" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn  Binding="{Binding Percent, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="%" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding PurchaseValue, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Buy" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn  Binding="{Binding TodayValue, StringFormat=N2}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Gesamtwert" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn  Binding="{Binding Provider}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Provider" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding Updated, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}">
                        <DataGridTextColumn.Header>
                            <TextBlock>
                                <Run Text="Updated" /><LineBreak /><Run Text=" " />
                            </TextBlock>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Splitter -->
        <GridSplitter    Grid.Column="1" Width="8" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowsPreview="True"/>
        
        <Border Grid.Column="2" Background="#FFFFddFF">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF666666" >Rechts - Bereich 1</TextBlock>
        </Border>
        
     
    </Grid>
</Window>

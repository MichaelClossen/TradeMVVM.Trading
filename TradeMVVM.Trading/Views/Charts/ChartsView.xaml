<UserControl x:Class="TradeMVVM.Trading.Views.Charts.ChartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">



    <Grid x:Name="ChartsRootGrid" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="AlertsColumn" Width="320" MinWidth="220" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <!-- give the PL panel a fixed height so it remains visible above the other charts -->
            <RowDefinition Height="250" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- Alert list on the left side -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                Background="#111111"
                CornerRadius="5"
                Padding="8">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Alert-Center"
                               Grid.Column="0"
                               Foreground="White"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AlertStatusTime}"
                               Grid.Column="1"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="20"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="12,0,0,0" />
                </Grid>

                <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtAlertToast" Foreground="Orange" Margin="0,0,0,8" TextWrapping="Wrap" />
                    <StackPanel>
                        <!-- PL values above the buttons, stacked vertically (left-aligned) -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,0,6">
                            <TextBlock x:Name="TxtTotalPLTop" Text="0.00 €" Foreground="White" FontWeight="Bold" HorizontalAlignment="Left" />
                            <TextBlock x:Name="TxtTotalPLTopDeltaStart" Text="" Foreground="LightGray" FontSize="12" HorizontalAlignment="Left" />
                            <TextBlock x:Name="TxtTotalPLTopDeltaPrev" Text="" Foreground="LightGray" FontSize="12" HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Buttons moved below the points list -->
                    </StackPanel>
                    <TextBlock Text="Holdings CSV:" Foreground="LightGray" Margin="0,6,0,2" FontWeight="Bold" />
                    <TextBlock x:Name="TxtHoldingsCsvPath" Text="(nicht konfiguriert)" Foreground="LightGray" TextWrapping="Wrap" MaxWidth="260" />
                    <StackPanel Orientation="Vertical" Margin="0,6,0,0">
                        <TextBlock Text="{Binding AlertStatusProcesses}" Foreground="LightGray" FontSize="12" />
                        <TextBlock Text="{Binding AlertStatusStocks}" Foreground="LightGray" FontSize="12" />
                        <TextBlock Text="{Binding AlertStatusHistory}" Foreground="LightGray" FontSize="12" />
                        <TextBlock Text="{Binding AlertMessage}" Foreground="Orange" FontSize="12" />
                        <WrapPanel Margin="0,6,0,0">
                            <Button x:Name="BtnAlertTest" Content="Test" Margin="0,0,6,0" Click="BtnAlertTest_Click" />
                            <Button x:Name="BtnAlertJump" Content="Zum Chart" Margin="0,0,6,0" Click="BtnAlertJump_Click" />
                            <Button x:Name="BtnAlertClear" Content="Leeren" Click="BtnAlertClear_Click" />
                            <Button x:Name="BtnFearGreed" Content="Fear &amp; Greed" Margin="6,0,0,0" Click="BtnFearGreed_Click" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="LstAlerts"
                         Background="#1C1C1C"
                         Foreground="LightGray"
                         BorderBrush="#333333"
                         DisplayMemberPath="Display"
                         MouseDoubleClick="LstAlerts_MouseDoubleClick" />
            </DockPanel>
        </Border>

        <GridSplitter x:Name="AlertsColumnSplitter" Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#2B2B2B"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True" />

        <!-- PL value removed from its own panel; value is shown next to the default button in the Stocks panel -->

        <!-- TOP stocks plot (fills previously reserved PL area) -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="#111111"
                CornerRadius="5"
                Padding="6"
                Margin="0,0,0,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                    <TextBlock Text="Ymin:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtStocksTopYMin" Width="80" Margin="4,0,0,0" />
                    <TextBlock Text="Ymax:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtStocksTopYMax" Width="80" Margin="4,0,0,0" />
                    <Button x:Name="BtnStocksTopApply" Content="Apply" Margin="8,0,0,0" Click="BtnStocksTopApply_Click" />
                    <Button x:Name="BtnStocksTopAuto" Content="Auto" Margin="4,0,0,0" Click="BtnStocksTopAuto_Click" />
                </StackPanel>
                <ScottPlot:WpfPlot x:Name="PlotStocksTop" Margin="5"/>
            </DockPanel>
        </Border>

        <!-- Main stocks plot filling the middle row -->
        <Border Grid.Column="2" Grid.Row="1"
                Background="#111111"
                CornerRadius="5"
                Padding="6"
                Margin="0,0,0,5">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="Stocks / ETF"
                               Foreground="White"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtTotalPL" Text="0.00 €" Foreground="White" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" />
                    </StackPanel>

                    <!-- runtime status display (moved to Alert-Center) -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtStatusProcesses" Foreground="LightGray" Margin="0,0,12,0" />
                        <TextBlock x:Name="TxtStatusStocks" Foreground="LightGray" Margin="0,0,12,0" />
                        <TextBlock x:Name="TxtStatusHistory" Foreground="LightGray" Margin="0,0,12,0" />
                        <TextBlock x:Name="TxtStatusTime" Foreground="LightGray" />
                    </StackPanel>

                </Grid>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,6,4">
                    <TextBlock Text="Ymin:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtStocksYMin" Width="80" Margin="4,0,0,0" />
                    <TextBlock Text="Ymax:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtStocksYMax" Width="80" Margin="4,0,0,0" />
                    <Button x:Name="BtnStocksApply" Content="Apply" Margin="8,0,0,0" Click="BtnStocksApply_Click" />
                    <Button x:Name="BtnStocksAuto" Content="Auto" Margin="4,0,0,0" Click="BtnStocksAuto_Click" />
                </StackPanel>
                <ScottPlot:WpfPlot x:Name="PlotStocks" Margin="5"/>
            </DockPanel>
        </Border>

        <!-- KNOCKOUTS on the bottom row -->
        <Border Grid.Column="2" Grid.Row="2"
                Background="#111111"
                CornerRadius="5"
                Padding="6">
            <DockPanel>
                <TextBlock Text="Knockouts"
                           DockPanel.Dock="Top"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="5"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,6,4">
                    <TextBlock Text="Ymin:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtKnockoutsYMin" Width="80" Margin="4,0,0,0" />
                    <TextBlock Text="Ymax:" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox x:Name="TxtKnockoutsYMax" Width="80" Margin="4,0,0,0" />
                    <Button x:Name="BtnKnockoutsApply" Content="Apply" Margin="8,0,0,0" Click="BtnKnockoutsApply_Click" />
                    <Button x:Name="BtnKnockoutsAuto" Content="Auto" Margin="4,0,0,0" Click="BtnKnockoutsAuto_Click" />
                </StackPanel>
                <ScottPlot:WpfPlot x:Name="PlotKnockouts" Margin="5"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="TradeMVVM.Trading.Views.Toolbar.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="8"
            CornerRadius="5"
            Background="#2A2A2A">

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    Width="70"
                    Margin="2"/>

            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    Width="70"
                    Margin="2"/>

            <Button Content="Server Start" Command="{Binding ServerStartCommand}" Width="90" Margin="2"/>
            <Button Content="Server Stop" Command="{Binding ServerStopCommand}" Width="90" Margin="2"/>

            <Button Content="Kill Chrome"
                    Width="90"
                    Margin="2"
                    Click="KillChromeButton_Click"/>

            <Separator Width="20"/>

            <Grid Margin="4,0,0,0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- top row: left label, slider, right label, current selection -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="1m" Foreground="LightGray" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider Grid.Row="0" Grid.Column="1" x:Name="ZoomRangeSlider"
                        Width="260"
                        Minimum="0"
                        Maximum="13"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        Value="5"
                        ValueChanged="ZoomRangeSlider_ValueChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Auto" Foreground="LightGray" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TxtZoomRange"
                           Foreground="White"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Text="2h"/>

                <!-- bottom row: tick labels aligned to slider columns -->
                <Grid Grid.Row="1" Grid.Column="1" Width="260" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="1m" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="1" Text="5m" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="2" Text="15m" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="3" Text="30m" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="4" Text="1h" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="5" Text="2h" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="6" Text="4h" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="7" Text="6h" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="8" Text="8h" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="9" Text="1D" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="10" Text="1W" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="11" Text="1M" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="12" Text="1Y" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                    <TextBlock Grid.Column="13" Text="Auto" HorizontalAlignment="Center" Foreground="LightGray" FontSize="10"/>
                </Grid>
            </Grid>

            <!-- Holdings totals removed from toolbar -->

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <Button Content="Clear DB" Command="{Binding ClearDbCommand}" Width="70" Margin="2"/>
                <Button Content="Preferences" Command="{Binding OpenSettingsCommand}" Width="90" Margin="8,2,2,2"/>
                <Button Content="Default" Width="75" Margin="2" Click="ResetLayoutDefaultsButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>

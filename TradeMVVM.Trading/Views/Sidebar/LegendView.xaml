<UserControl x:Class="TradeMVVM.Trading.Views.Sidebar.LegendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#2A2A2A"
            CornerRadius="5"
            Padding="10">

        <DockPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                <TextBlock Text="Aktive Werte" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                    <Button Content="Aktualisieren" Click="OnRefreshClicked" Margin="6,0" />
                    <Button Content="Export CSV" Click="OnExportClicked" Margin="6,0" />
                </StackPanel>
            </StackPanel>

            <DataGrid ItemsSource="{Binding LegendItems}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowBackground="#2A2A2A" AlternatingRowBackground="#303030" GridLinesVisibility="None" Foreground="White">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="30">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Rectangle Width="15" Height="15" Fill="{Binding Color}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />

                    <DataGridTextColumn Header="%" Binding="{Binding PercentText}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PercentBrush}" Value="{x:Null}">
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>

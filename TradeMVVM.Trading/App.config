<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Comma-separated keywords that will prioritize BNP provider when present in instrument name -->
    <add key="BnpPriorityKeywords" value="long,short,turbo" />
    <!-- Enable or disable BNP priority behavior -->
    <add key="BnpPriorityEnabled" value="true" />
  </appSettings>
</configuration>